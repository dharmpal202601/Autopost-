    "poll_interval_seconds": 60,
    "poll_jitter_seconds": 30
  },
  "meta": {
    "app_id": "YOUR_META_APP_ID",
    "app_secret_encrypted": "",
    "page_id": "YOUR_FACEBOOK_PAGE_ID",
    "page_access_token_encrypted": "",
    "ig_user_id": "YOUR_INSTAGRAM_USER_ID",
